{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/",
      "has": [
        {
          "type": "host",
          "value": "obreirosrv.saraitapema.com.br"
        }
      ],
      "dest": "/public/obreiros.html"
    },
    {
      "src": "/",
      "has": [
        {
          "type": "host",
          "value": "inscricaorv.saraitapema.com.br"
        }
      ],
      "dest": "/public/inscricao.html"
    },
    {
      "src": "/",
      "has": [
        {
          "type": "host",
          "value": "painelrv.saraitapema.com.br"
        }
      ],
      "dest": "/public/painel-admin.html"
    },
    {
      "src": "/",
      "has": [
        {
          "type": "host",
          "value": "lideresrv.saraitapema.com.br"
        }
      ],
      "dest": "/public/lideres.html"
    },
    {
      "src": "/",
      "dest": "/public/inscricao.html"
    },
    {
      "src": "/painel",
      "dest": "/public/painel-admin.html"
    },
    {
      "src": "/obreiros",
      "dest": "/public/obreiros.html"
    },
    {
      "src": "/lideres",
      "dest": "/public/lideres.html"
    },
    {
      "src": "/painel-admin.html",
      "dest": "/public/painel-admin.html"
    },
    {
      "src": "/inscricao.html",
      "dest": "/public/inscricao.html"
    },
    {
      "src": "/obreiros.html",
      "dest": "/public/obreiros.html"
    },
    {
      "src": "/lideres.html",
      "dest": "/public/lideres.html"
    },
    {
      "src": "/(.*\\.(png|jpeg|jpg|gif|ico|svg|webp))",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
